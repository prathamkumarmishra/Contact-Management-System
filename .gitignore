# ============================================
# Smart Contact Management System - .gitignore
# ============================================

# Dependencies
node_modules/
.pnp
.pnp.js

# Build outputs
dist/
build/
out/
*.js.map

# C++ build artifacts
cpp-engine/build/
cpp-engine/bin/
cpp-engine/lib/
*.o
*.obj
*.exe
*.out
*.a
*.so
*.dylib
*.dll
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
Makefile

# Environment variables
.env
.env.local
.env.development
.env.production
.env.test
!.env.example

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Runtime
pids
*.pid
*.seed
*.pid.lock

# Coverage & Testing
coverage/
*.lcov
.nyc_output

# IDE & Editor
.vscode/
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/

# OS
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Uploads (runtime)
backend/src/uploads/*
!backend/src/uploads/.gitkeep

# Temporary files
tmp/
temp/
*.tmp

# TypeScript
*.tsbuildinfo

# Vite
vite.config.ts.timestamp-*

# Docker
.dockerignore

# Misc
.cache
.parcel-cache
